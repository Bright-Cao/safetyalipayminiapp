PORT=3000

# 数据库连接 (一旦服务器购买好，把这里的地址换成实际的内网或外网IP即可)
# 例如: MONGODB_URI=mongodb://admin:password@127.0.0.1:27017/training_db?authSource=admin
MONGODB_URI=mongodb://127.0.0.1:27017/training_db

# 核心安全盐：这是服务器识别用户 JWT 令牌合法性的唯一钥匙，请妥善保管，防伪造机制全靠它
JWT_SECRET=migrant_secure_super_secret_key_8899

# 以下如果有云存储等，可以顺延增加
# OSS_ACCESS_KEY=...
