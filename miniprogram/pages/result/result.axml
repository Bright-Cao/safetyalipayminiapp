<view class="container">
  <!-- 🚀 证书展示（高级版） -->
  <view class="certificate-container" a:if="{{hasCertificate}}">
    <view class="cert-card-outer">
      <view class="cert-card-inner">
        <!-- 侧边装饰条 -->
        <view class="decoration-bar"></view>
        
        <view class="cert-header">
          <view class="cert-logo">🛡️</view>
          <view class="header-text">
            <text class="cert-title">{{certificate.categoryName}}学习结业记录</text>
            <text class="cert-subtitle">安全知识个人学习自测系统</text>
          </view>
        </view>

        <view class="cert-main">
          <view class="photo-section">
            <image class="user-photo" src="{{certificate.photo || 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTAwIiBoZWlnaHQ9IjEwMCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cmVjdCB3aWR0aD0iMTAwIiBoZWlnaHQ9IjEwMCIgZmlsbD0iI2U4ZThlOCIvPjx0ZXh0IHg9IjUwIiB5PSI2MCIgZm9udC1zaXplPSI0MCIgdGV4dC1hbmNob3I9Im1pZGRsZSIgZmlsbD0iIzk5OSI+8J+RpDwvdGV4dD48L3N2Zz4='}}" mode="aspectFill"></image>
            <view class="verify-badge">测评达标</view>
          </view>

          <view class="info-section">
            <view class="grid-info">
              <view class="grid-item">
                <text class="grid-label">姓名</text>
                <text class="grid-value highlight">{{certificate.name}}</text>
              </view>
              <view class="grid-item">
                <text class="grid-label">学习所属</text>
                <text class="grid-value">{{certificate.workshop}}</text>
              </view>
              <view class="grid-item">
                <text class="grid-label">经验值</text>
                <text class="grid-value" a:if="{{certificate.category === 'guardian'}}">{{certificate.workYears}}级</text>
                <text class="grid-value" a:elif="{{certificate.category === 'safety_manager' || certificate.category === 'safety_officer'}}">{{certificate.safetyManagementYears}}级</text>
                <text class="grid-value" a:else>{{certificate.siteManagementYears}}级</text>
              </view>
              <view class="grid-item">
                <text class="grid-label">学习编号</text>
                <text class="grid-value mono">{{certificate.certNumber}}</text>
              </view>
            </view>

            <view class="details-list">
              <view class="detail-row">
                <text class="dot">●</text>
                <text class="detail-label">证件号码：</text>
                <text class="detail-value">{{certificate.idCard}}</text>
              </view>
              <view class="detail-row">
                <text class="dot">●</text>
                <text class="detail-label">完成日期：</text>
                <text class="detail-value">{{certificate.issueDate}}</text>
              </view>
              <view class="detail-row">
                <text class="dot">●</text>
                <text class="detail-label">有效日期：</text>
                <text class="detail-value highlight-expiry">{{certificate.expiryDate}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="cert-footer">
          <view class="qr-placeholder">
            <text class="qr-text">扫码详情</text>
          </view>
          <view class="footer-seal">
            <text class="seal-text">学习助手</text>
            <view class="seal-circle"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="cert-actions">
      <view class="action-item" onTap="downloadCert">
        <view class="action-icon bg-blue">📥</view>
        <text>下载保存</text>
      </view>
      <view class="action-item" onTap="shareCert">
        <view class="action-icon bg-green">📤</view>
        <text>分享好友</text>
      </view>
    </view>
  </view>

  <!-- 无证书状态 -->
  <view class="card" a:if="{{!hasCertificate}}">
    <view class="empty-state">
      <text class="empty-icon">📜</text>
      <text class="empty-text">暂无学习记录</text>
      <text class="empty-desc">{{emptyMessage}}</text>
      <button class="btn-primary" onTap="goToApply" a:if="{{canApply}}">开始学习计划</button>
    </view>
  </view>

  <!-- 成绩记录 -->
  <view class="card" a:if="{{hasCertificate}}">
    <view class="card-title">测评成绩</view>
    <view class="score-list">
      <view class="score-item">
        <text class="score-label">水平测评</text>
        <text class="score-value">{{certificate.interviewScore}}分</text>
        <text class="score-status pass">达标</text>
      </view>
      <view class="score-item">
        <text class="score-label">自测卷成绩</text>
        <text class="score-value">{{certificate.examScore}}分</text>
        <text class="score-status pass">达标</text>
      </view>
    </view>
  </view>

  <!-- 培训记录 -->
  <view class="card" a:if="{{trainingRecords.length > 0}}">
    <view class="card-title">培训记录</view>
    <view class="record-list">
      <view class="record-item" a:for="{{trainingRecords}}" a:key="id">
        <view class="record-dot"></view>
        <view class="record-content">
          <text class="record-title">{{item.title}}</text>
          <text class="record-time">{{item.time}}</text>
        </view>
        <view class="record-status completed">已完成</view>
      </view>
    </view>
  </view>
</view>
