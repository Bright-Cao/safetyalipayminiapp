<!--pages/check/check.axml-->
<view class="container">
  <view class="search-card">
    <!-- 输入查询 -->
    <view class="search-input-area">
      <view class="search-box">
        <input class="search-input" placeholder="请输入姓名或身份证号" value="{{keyword}}" onInput="onKeywordInput" confirm-type="search" onConfirm="handleSearch" />
        <button class="search-btn" onTap="handleSearch">查询</button>
      </view>
      <view class="search-tip">
        <text>💡 可通过姓名或身份证号核对学习达标情况</text>
      </view>
    </view>
  </view>

  <!-- 查询结果 -->
  <view class="result-section" a:if="{{searchResult}}">
    <view class="result-card {{searchResult.status === 'qualified' ? 'qualified' : 'unqualified'}}">
      <view class="result-header">
        <view class="status-badge {{searchResult.status === 'qualified' ? 'success' : 'error'}}">
          {{searchResult.status === 'qualified' ? '✓ 已达标' : '✗ 未达标'}}
        </view>
      </view>

      <view class="person-info">
        <view class="avatar">
          <image src="{{searchResult.avatar || 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTAwIiBoZWlnaHQ9IjEwMCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cmVjdCB3aWR0aD0iMTAwIiBoZWlnaHQ9IjEwMCIgZmlsbD0iI2U4ZThlOCIvPjx0ZXh0IHg9IjUwIiB5PSI2MCIgZm9udC1zaXplPSI0MCIgdGV4dC1hbmNob3I9Im1pZGRsZSIgZmlsbD0iIzk5OSI+8J+RpDwvdGV4dD48L3N2Zz4='}}" mode="aspectFill"></image>
        </view>
        <view class="info-content">
          <text class="person-name">{{searchResult.name}}</text>
          <text class="person-id">{{searchResult.idCard}}</text>
          <text class="person-company">{{searchResult.company}}</text>
        </view>
      </view>

      <view class="cert-info" a:if="{{searchResult.status === 'qualified'}}">
        <view class="info-row">
          <text class="info-label">类型：</text>
          <text class="info-value">{{searchResult.applicantType === 'internal' ? '本厂' : '协作'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">年龄：</text>
          <text class="info-value">{{searchResult.age ? searchResult.age + '岁' : '未填写'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">车间/科室：</text>
          <text class="info-value">{{searchResult.workshop}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">厂龄：</text>
          <text class="info-value">{{searchResult.workYears ? searchResult.workYears + '年' : '未填写'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">组长：</text>
          <text class="info-value">{{searchResult.isTeamLeader === 'yes' ? '是' : '否'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">学习编号：</text>
          <text class="info-value">{{searchResult.certNumber}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">达标时间：</text>
          <text class="info-value">{{searchResult.certDate}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">有效期至：</text>
          <text class="info-value">{{searchResult.expiryDate}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">水平成绩：</text>
          <text class="info-value">{{searchResult.interviewScore}}分</text>
        </view>
        <view class="info-row">
          <text class="info-label">测评成绩：</text>
          <text class="info-value">{{searchResult.examScore}}分</text>
        </view>
      </view>

      <view class="unqualified-info" a:if="{{searchResult.status !== 'qualified'}}">
        <text class="unqualified-text">该人员暂未完成学习计划</text>
        <text class="unqualified-reason">{{searchResult.reason}}</text>
      </view>

    </view>

    <!-- 培训记录 -->
    <view class="card" a:if="{{searchResult.trainingRecords && searchResult.trainingRecords.length > 0}}">
      <view class="card-title">自学记录</view>
      <view class="training-list">
        <view class="training-item" a:for="{{searchResult.trainingRecords}}" a:key="id">
          <view class="training-dot"></view>
          <view class="training-content">
            <text class="training-title">{{item.title}}</text>
            <text class="training-time">{{item.time}}</text>
          </view>
          <view class="training-status {{item.completed ? 'completed' : 'pending'}}">
            {{item.completed ? '已完成' : '进行中'}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 无结果 -->
  <view class="empty-state" a:if="{{searched && !searchResult}}">
    <text class="empty-icon">🔍</text>
    <text class="empty-text">未找到相关信息</text>
    <text class="empty-desc">请检查输入的姓名或身份证号是否正确</text>
  </view>

  <!-- 快速查询历史 -->
  <view class="card" a:if="{{searchHistory.length > 0 && !searchResult}}">
    <view class="card-title">
      <text>查询历史</text>
      <text class="clear-history" onTap="clearHistory">清空</text>
    </view>
    <view class="history-list">
      <view class="history-item" a:for="{{searchHistory}}" a:key="keyword" onTap="quickSearch" data-keyword="{{item.keyword}}">
        <text class="history-icon">🕐</text>
        <text class="history-text">{{item.keyword}}</text>
        <text class="history-time">{{item.time}}</text>
      </view>
    </view>
  </view>
</view>
