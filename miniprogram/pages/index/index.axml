<!--pages/index/index.axml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-avatar">
      <image src="{{userInfo.avatar || 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTAwIiBoZWlnaHQ9IjEwMCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cmVjdCB3aWR0aD0iMTAwIiBoZWlnaHQ9IjEwMCIgZmlsbD0iI2U4ZThlOCIvPjx0ZXh0IHg9IjUwIiB5PSI2MCIgZm9udC1zaXplPSI0MCIgdGV4dC1hbmNob3I9Im1pZGRsZSIgZmlsbD0iIzk5OSI+8J+RpDwvdGV4dD48L3N2Zz4='}}" mode="aspectFill"></image>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.name || '未填写姓名'}}</text>
      <text class="user-phone">{{userInfo.phone}}</text>
    </view>
    <view class="user-status">
      <view class="workshop-tag" a:if="{{userInfo.workshop_name}}">当前：{{userInfo.workshop_name}}</view>
      <view class="status-badge {{statusClass}}">{{statusText}}</view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="function-grid">
    <view class="function-item" onTap="goToApply" a:if="{{!hasApplication || canReapply}}">
      <view class="icon-wrapper" style="background: #1890ff;">
        <text class="icon">📝</text>
      </view>
      <text class="function-text">申请</text>
    </view>

    <view class="function-item" onTap="goToTraining" a:if="{{showTraining}}">
      <view class="icon-wrapper" style="background: #52c41a;">
        <text class="icon">🎓</text>
      </view>
      <text class="function-text">培训学习</text>
    </view>

    <view class="function-item" onTap="goToExam" a:if="{{showExam}}">
      <view class="icon-wrapper" style="background: #fa8c16;">
        <text class="icon">📋</text>
      </view>
      <text class="function-text">知识自测</text>
    </view>

    <view class="function-item" onTap="goToResult">
      <view class="icon-wrapper" style="background: #722ed1;">
        <text class="icon">🏆</text>
      </view>
      <text class="function-text">查看证书</text>
    </view>

    <view class="function-item" onTap="goToPractice">
      <view class="icon-wrapper" style="background: #eb2f96;">
        <text class="icon">📖</text>
      </view>
      <text class="function-text">题库练习</text>
    </view>

    <view class="function-item" onTap="handleLogout">
      <view class="icon-wrapper" style="background: #999;">
        <text class="icon">🔄</text>
      </view>
      <text class="function-text">切换车间</text>
    </view>
  </view>

  <!-- 流程进度 -->
  <view class="card" a:if="{{application}}">
    <view class="card-title">学习进度 - {{application.category === 'guardian' ? '监护员' : (application.category === 'safety_manager' ? '管理员' : (application.category === 'safety_officer' ? '安全员' : '领班'))}}</view>
    <view class="progress-steps {{currentFlow.length <= 3 ? 'short-flow' : ''}}">
      <block a:for="{{currentFlow}}" a:key="name">
        <view class="step {{currentStep > index ? 'completed' : ''}} {{currentStep === index + 1 ? 'active' : ''}}">
          <view class="step-icon">{{index + 1}}</view>
          <text class="step-text">{{item.name}}</text>
        </view>
        <view class="step-line {{currentStep > index + 1 ? 'completed' : ''}}" a:if="{{index < currentFlow.length - 1}}"></view>
      </block>
    </view>

    <view class="progress-detail">
      <text class="detail-label">当前状态：</text>
      <text class="detail-value">{{statusText}}</text>
    </view>
    
    <view class="progress-detail" a:if="{{application.workshop}}">
      <text class="detail-label">申请车间：</text>
      <text class="detail-value">{{application.workshop}}</text>
    </view>

    <view class="progress-detail" a:if="{{application.interview_score}}">
      <text class="detail-label">面试成绩：</text>
      <text class="detail-value">{{application.interview_score}}分</text>
    </view>

    <view class="progress-detail" a:if="{{application.exam_score}}">
      <text class="detail-label">考试成绩：</text>
      <text class="detail-value">{{application.exam_score}}分</text>
    </view>
  </view>

  <!-- 通知公告 -->
  <view class="card">
    <view class="card-title">通知公告</view>
    <view class="notice-list">
      <view class="notice-item" a:for="{{notices}}" a:key="id" onTap="viewNotice" data-id="{{item.id}}">
        <view class="notice-dot"></view>
        <text class="notice-title">{{item.title}}</text>
        <text class="notice-time">{{item.time}}</text>
      </view>
    </view>
    <view class="empty-state" a:if="{{notices.length === 0}}">
      <text class="empty-text">暂无通知</text>
    </view>
  </view>
</view>
